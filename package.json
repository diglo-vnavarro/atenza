{
  "name": "organizate-ticketing-proto",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Atenza (nombre en clave) — piloto ITSM multi-tenant: núcleo de dominio, reglas Firestore y app local-first.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "import": "tsx importer/run.ts",
    "sync": "tsx scripts/sync-tickets.ts",
    "sync:dry": "tsx scripts/sync-tickets.ts --dry-run",
    "sync:job": "tsx importer/etl.ts && tsx scripts/sync-tickets.ts",
    "enrich:members": "tsx scripts/enrich-members.ts",
    "enrich:members:dry": "tsx scripts/enrich-members.ts --dry-run",
    "enrich:catalog": "tsx scripts/enrich-catalog.ts",
    "enrich:catalog:dry": "tsx scripts/enrich-catalog.ts --dry-run",
    "import:layouts": "tsx scripts/import-layouts.ts",
    "import:layouts:dry": "tsx scripts/import-layouts.ts --dry-run",
    "sync:organizate": "tsx scripts/sync-organizate.ts",
    "sync:organizate:dry": "tsx scripts/sync-organizate.ts --dry-run",
    "apply:catservicio": "tsx scripts/apply-service-categories.ts",
    "apply:catservicio:dry": "tsx scripts/apply-service-categories.ts --dry-run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\""
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
    "firebase": "^11.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "firebase-admin": "^14.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
