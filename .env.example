# Config web de Firebase (pública). Rellénala con los valores de:
#   cd infra/terraform && terraform output -json firebase_config
# En local, copia a .env.local (gitignored). En CI, ponlos como secrets del repo.
# Si NO se definen, la app funciona en modo local-first (localStorage), sin nube.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
