rules_version = '2';

// ============================================================================
// OrganiZate Ticketing — reglas de aislamiento multi-tenant (PROTOTIPO)
//
// Principio: TODO cuelga de /tenants/{tenantId}. El acceso se decide por la
// PERTENENCIA a ese tenant (documento members/{uid}) y por el ROL en él.
// NO hay ninguna comprobación de dominio de correo: un técnico o solicitante
// externo funciona igual que uno interno siempre que sea miembro del tenant.
// Esta es la diferencia estructural con OrganiZate (que bloquea @digloservicer.com).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ------------------------------------------------------------
    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function memberRef(tid) {
      return /databases/$(database)/documents/tenants/$(tid)/members/$(uid());
    }
    function isMember(tid) {
      return signedIn()
        && exists(memberRef(tid))
        && get(memberRef(tid)).data.status == 'active';
    }
    function memberData(tid) { return get(memberRef(tid)).data; }
    function roleIn(tid) { return memberData(tid).role; }
    function isAdmin(tid) { return isMember(tid) && roleIn(tid) == 'tenant_admin'; }
    // "técnico" incluye a tenant_admin (superconjunto operativo sobre tickets)
    function isTech(tid) { return isMember(tid) && roleIn(tid) in ['technician', 'tenant_admin']; }
    function isRequester(tid) { return isMember(tid) && roleIn(tid) == 'requester'; }
    // Capacidad granular del rol. Si el miembro trae `caps` (denormalizadas), se
    // consultan; si NO (miembros previos / seed), se cae al nivel base: solo
    // tenant_admin tiene capacidades de gestión. El fallback evita bloquear a los
    // administradores actuales al endurecer las reglas.
    function hasCap(tid, cap) {
      return isMember(tid)
        && ( ('caps' in memberData(tid)) ? (cap in memberData(tid).caps) : (roleIn(tid) == 'tenant_admin') );
    }

    // superadmin de plataforma (Diglo), fuera de todo tenant
    function isPlatformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/platformAdmins/$(uid()));
    }

    function ticketData(tid, ticketId) {
      return get(/databases/$(database)/documents/tenants/$(tid)/tickets/$(ticketId)).data;
    }

    // ---- plataforma ---------------------------------------------------------
    match /platformAdmins/{u} {
      allow read: if isPlatformAdmin();
      allow write: if false; // se gestiona fuera de banda (consola / Cloud Function)
    }

    // índice uid -> tenants a los que pertenece. Lo mantiene el superadmin al
    // sembrar/gestionar (a futuro, una Cloud Function al crear/borrar members).
    match /userTenants/{u} {
      allow read: if signedIn() && (u == uid() || isPlatformAdmin());
      allow write: if isPlatformAdmin();
    }

    // Cola de correo de la extensión Trigger Email. CANDADO DE FASE DE PRUEBAS:
    // solo se pueden encolar emails dirigidos al usuario de pruebas — ni un
    // cliente mal comportado puede enviar a terceros. La lee la extensión (admin).
    // En producción: mover el envío a una Cloud Function y relajar esta regla.
    match /mail/{id} {
      allow create: if signedIn() && request.resource.data.to == 'vnavarro@digloservicer.com';
      allow read, update, delete: if false;
    }

    // ---- tenant -------------------------------------------------------------
    match /tenants/{tid} {
      allow get:    if isMember(tid) || isPlatformAdmin();
      allow list:   if isPlatformAdmin();
      allow create: if isPlatformAdmin();
      allow update: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      allow delete: if isPlatformAdmin();

      // --- miembros del tenant (identidad + rol AQUÍ) ---
      match /members/{u} {
        allow get:  if isMember(tid) || isPlatformAdmin();
        allow list: if isTech(tid)   || isPlatformAdmin();
        allow create, update, delete: if hasCap(tid, 'manageUsers') || isPlatformAdmin();
      }

      // --- tickets ---
      match /tickets/{ticketId} {
        // Técnico/admin ven todo el tenant; el solicitante solo SUS tickets.
        allow get: if isTech(tid)
          || (isMember(tid) && resource.data.requesterId == uid())
          || isPlatformAdmin();

        // LIMITACIÓN conocida de Firestore: en un `list` las reglas no pueden
        // inspeccionar el filtro de la consulta. Por eso el listado libre queda
        // para técnico/admin; el solicitante recupera "sus" tickets vía una
        // consulta acotada validada en Cloud Function (o un índice por usuario).
        allow list: if isTech(tid) || isPlatformAdmin();

        // Crear: cualquier miembro activo. El solicitante solo puede crear
        // tickets a su propio nombre; técnico/admin pueden crear en nombre de otro.
        allow create: if isMember(tid)
          && request.resource.data.type in ['incident', 'service_request']
          && (isTech(tid) || request.resource.data.requesterId == uid());

        // Actualizar: técnico/admin sin límite. El solicitante solo su propio
        // ticket y sin tocar la asignación (no puede reasignar ni auto-asignarse).
        allow update: if isTech(tid)
          || (isRequester(tid)
              && resource.data.requesterId == uid()
              && request.resource.data.requesterId == resource.data.requesterId
              && request.resource.data.technicianId == resource.data.technicianId);

        allow delete: if isAdmin(tid) || isPlatformAdmin();

        // Sub-colecciones del ticket (conversaciones, trabajo, adjuntos):
        // mismo criterio de visibilidad que el ticket padre.
        match /{sub}/{docId} {
          allow read: if isTech(tid)
            || (isMember(tid) && ticketData(tid, ticketId).requesterId == uid())
            || isPlatformAdmin();
          allow create: if isTech(tid)
            || (isMember(tid) && ticketData(tid, ticketId).requesterId == uid());
          allow update, delete: if isTech(tid) || isPlatformAdmin();
        }
      }

      // --- configuración del tenant (lectura: miembros; escritura: admin) ---
      // Colecciones separadas a propósito: Firestore no permite alternancia en
      // el segmento de ruta, y un comodín ancho ampliaría permisos por error.
      // categorías y capacidad viven en el propio doc del tenant (get: miembro).
      match /lifecycles/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /templates/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /catalog/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /slas/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /workflows/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /groups/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }
      match /approvals/{docId} {
        allow read:  if isMember(tid) || isPlatformAdmin();
        allow write: if hasCap(tid, 'manageConfig') || isPlatformAdmin();
      }

      // --- avisos en pantalla: cada miembro solo lee/actualiza LOS SUYOS ---
      // (la consulta filtra por forUid==uid; el `read` lo exige por documento).
      // Crear lo permite cualquier miembro porque los eventos que disparan un
      // aviso los provoca un miembro (p. ej. un solicitante que crea un ticket
      // notifica a los técnicos).
      match /notifications/{docId} {
        allow read:   if (isMember(tid) && resource.data.forUid == uid()) || isPlatformAdmin();
        allow create: if isMember(tid);
        allow update: if (isMember(tid) && resource.data.forUid == uid()) || isPlatformAdmin();
        allow delete: if isAdmin(tid)  || isPlatformAdmin();
      }

      // Registro de auditoría: append-only. Cualquier miembro crea; lee staff/admin;
      // NO se actualiza ni borra (traza inmutable).
      match /audit/{docId} {
        allow read:   if isTech(tid) || isPlatformAdmin();
        allow create: if isMember(tid);
        allow update, delete: if false;
      }
    }
  }
}
