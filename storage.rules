rules_version = '2';

// Reglas de Cloud Storage para adjuntos de tickets, organizadas por tenant:
//   tenants/{tenantId}/tickets/{ticketId}/{fileName}
//
// LIMITACIÓN conocida: las reglas de Storage NO pueden consultar Firestore, así
// que no pueden comprobar la pertenencia al tenant (rol/miembro). Aquí se exige
// estar autenticado + estructura de ruta + límite de tamaño; el control fino de
// acceso por tenant se refuerza en la app y (a futuro) con URLs firmadas emitidas
// por una Cloud Function que sí valida pertenencia.
service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/{tenantId}/tickets/{ticketId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10 MB
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
